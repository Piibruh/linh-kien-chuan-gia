generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. Bảng Tài Khoản
model TaiKhoan {
  maTaiKhoan  String   @id @default(uuid())
  tenDangNhap String   @unique
  matKhau     String
  quyenHan    String   @default("USER")
  trangThai   Int      @default(1)
  ngayTao     DateTime @default(now())

  nguoiDung NguoiDung?
}

// 2. Bảng Người Dùng
model NguoiDung {
  maNguoiDung String   @id @default(uuid())
  maTaiKhoan  String   @unique
  taiKhoan    TaiKhoan @relation(fields: [maTaiKhoan], references: [maTaiKhoan], onDelete: Cascade)
  hoTen       String
  email       String   @unique
  dienThoai   String?
  diaChi      String?

  gioHangs GioHang[]
  donHangs DonHang[]
  danhGias DanhGia[]
}

// 3. Bảng Danh mục
model DanhMuc {
  maDanhMuc  String  @id @default(uuid())
  tenDanhMuc String
  moTa       String?

  sanPhams SanPham[]
}

// 4. Bảng Sản phẩm
model SanPham {
  maSanPham  String  @id @default(uuid())
  maDanhMuc  String
  danhMuc    DanhMuc @relation(fields: [maDanhMuc], references: [maDanhMuc])
  tenSanPham String
  thuongHieu String
  giaBan     Float
  soLuongTon Int
  baoHanh    String?
  moTaKT     String?
  huongDan   String?
  trangThai  String  @default("published")
  hienThi    String  @default("public")
  seoTitle   String?
  seoDescription String?
  seoKeywords    String?
  tags       String?
  ngayXuatBan DateTime @default(now())
  luotXem    Int @default(0)
  soLanSua   Int @default(0)
  nguoiSuaCuoi String?

  hinhAnhs   HinhAnh[]
  thongSos   ThongSo[]
  ctGioHangs ChiTietGioHang[]
  ctDonHangs ChiTietDonHang[]
  danhGias   DanhGia[]
}

// 5. Bảng Thông số kỹ thuật
model ThongSo {
  maThongSo  String  @id @default(uuid())
  maSanPham  String
  sanPham    SanPham @relation(fields: [maSanPham], references: [maSanPham], onDelete: Cascade)
  tenThongSo String
  giaTri     String
}

// 6. Bảng Hình ảnh
model HinhAnh {
  maHinh     String  @id @default(uuid())
  maSanPham  String
  sanPham    SanPham @relation(fields: [maSanPham], references: [maSanPham], onDelete: Cascade)
  url        String
  thuTu      Int     @default(0)
  laAnhChinh Boolean @default(false)
}

// 6. Bảng Giỏ hàng
model GioHang {
  maGioHang   String    @id @default(uuid())
  maNguoiDung String
  nguoiDung   NguoiDung @relation(fields: [maNguoiDung], references: [maNguoiDung], onDelete: Cascade)

  chiTiet ChiTietGioHang[]
}

// 7. Bảng Chi tiết giỏ hàng
model ChiTietGioHang {
  maCTGH    String  @id @default(uuid())
  maGioHang String
  gioHang   GioHang @relation(fields: [maGioHang], references: [maGioHang], onDelete: Cascade)
  maSanPham String
  sanPham   SanPham @relation(fields: [maSanPham], references: [maSanPham], onDelete: Cascade)
  soLuong   Int
}

// 8. Bảng Đơn hàng
model DonHang {
  maDonHang    String    @id @default(uuid())
  maNguoiDung  String
  nguoiDung    NguoiDung @relation(fields: [maNguoiDung], references: [maNguoiDung])
  tenNguoiNhan String
  sdtNhan      String
  ngayDat      DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tongTien     Float
  trangThai    String    @default("Cho_Xu_Ly")
  diaChiGiao   String
  ghiChu       String?
  lyDoHuy      String?   
  ghiChuHuy    String?   

  confirmedAt  DateTime?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  codCollectedAt DateTime?

  chiTiet   ChiTietDonHang[]
  thanhToan ThanhToan[]
  vanChuyen VanChuyen[]
}

// 9. Bảng Chi tiết đơn hàng
model ChiTietDonHang {
  maChiTiet String  @id @default(uuid())
  maDonHang String
  donHang   DonHang @relation(fields: [maDonHang], references: [maDonHang], onDelete: Cascade)
  maSanPham String
  sanPham   SanPham @relation(fields: [maSanPham], references: [maSanPham])
  soLuong   Int
  donGia    Float
}

// 10. Bảng Thanh toán
model ThanhToan {
  maThanhToan String    @id @default(uuid())
  maDonHang   String
  donHang     DonHang   @relation(fields: [maDonHang], references: [maDonHang], onDelete: Cascade)
  phuongThuc  String
  trangThai   String
  ngayTT      DateTime? @default(now())
}

// 11. Bảng Vận chuyển
model VanChuyen {
  maVanChuyen  String  @id @default(uuid())
  maDonHang    String
  donHang      DonHang @relation(fields: [maDonHang], references: [maDonHang], onDelete: Cascade)
  donVi        String
  phiVanChuyen Float
  trangThai    String
}

// 12. Bảng Đánh giá
model DanhGia {
  maDanhGia   String    @id @default(uuid())
  maSanPham   String
  sanPham     SanPham   @relation(fields: [maSanPham], references: [maSanPham], onDelete: Cascade)
  maNguoiDung String
  nguoiDung   NguoiDung @relation(fields: [maNguoiDung], references: [maNguoiDung], onDelete: Cascade)
  diem        Int
  binhLuan    String
  ngayTao     DateTime  @default(now())
}
